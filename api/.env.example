SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-key
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ── WhatsApp Cloud API ─────────────────────────────────────────────────────────
# Obtener en developers.facebook.com → tu app → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAxxxxxxxxxx          # token temporal (expira cada ~24hs en pruebas)
WHATSAPP_PHONE_NUMBER_ID=1234567890   # ID del número de prueba o producción
WHATSAPP_APP_SECRET=abc123            # Settings → Basic → App Secret (para verificar firmas)
WHATSAPP_VERIFY_TOKEN=vectorai-webhook-2026  # string que vos elegís, lo ponés igual en Meta
